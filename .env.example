# ------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# Never commit .env to git.
# ------------------------------------------------------------

# Google Gemini API key (https://aistudio.google.com/apikey)
# Used for BOTH answer generation and embeddings.
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HTTP port for the webhook server
PORT=3000

# Optional: process only this single source file (relative or absolute path).
# If left commented out, ocr.js and ingest.js process ALL .pdf/.pptx files
# inside source-files/ and merge them into one knowledge base.
# SOURCE_FILE=source-files/your-document.pdf

# Gemini model to use for answer generation.
# Check https://ai.google.dev/gemini-api/docs/models for the latest list.
# - gemini-flash-lite-latest: fastest, ~2-3s response, fewer 503s (recommended)
# - gemini-2.5-flash: more capable but ~6-9s response and frequent 503s
# - gemini-2.5-pro: highest quality, slowest
GEMINI_MODEL=gemini-flash-lite-latest

# Gemini embedding model (used by both ingest.js and rag.js).
# gemini-embedding-001: stable, Matryoshka dims (we use 768), multilingual.
EMBED_MODEL=gemini-embedding-001

# Number of top chunks to retrieve per question
TOP_K=4
